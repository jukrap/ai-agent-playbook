{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"<path-to-ai-agent-playbook>/adapters/claude-code/hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"<path-to-ai-agent-playbook>/adapters/claude-code/hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
