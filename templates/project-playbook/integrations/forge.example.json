{
  "automation": {
    "profile": "deliver",
    "killSwitch": true,
    "queue": {
      "readyLabel": "status:ready",
      "pauseLabel": "status:paused",
      "maxParallel": 1
    },
    "budget": {
      "tickMinutes": 30,
      "maxAttempts": 3,
      "maxStalled": 3,
      "maxWallMinutes": 480
    }
  },
  "forge": {
    "provider": "auto",
    "remote": "origin",
    "apiBaseUrl": null,
    "sync": "hybrid",
    "language": "auto",
    "autoBootstrap": true,
    "presentation": {
      "issueMode": "delivery-group",
      "maxChildIssues": 6,
      "titleStyle": "auto",
      "bodyDetail": "reviewable",
      "labelStrategy": "minimal"
    },
    "projectMode": "preferred",
    "onMissingCapability": "pause"
  },
  "git": {
    "strategy": "branch",
    "unattendedWorkspace": "isolated-checkout",
    "branchPrefix": "aapb/",
    "autoCommit": true,
    "autoPush": true,
    "allowForcePush": false
  },
  "executor": {
    "provider": "auto",
    "command": null
  }
}
